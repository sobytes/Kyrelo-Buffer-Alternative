# Required: AI provider used by the @grok reply generator
ANTHROPIC_API_KEY=

# Optional: switch the detector's AI provider to OpenAI from the UI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Release credentials (only needed to run `npm run release:mac`) ---
# Generate an app-specific password at https://appleid.apple.com → Sign-In and Security
# Team ID is the 10-char string in your Developer ID Application certificate.
# APPLE_ID=you@example.com
# APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx
# APPLE_TEAM_ID=FT97GD7996

# Optional: force git push during release to use a specific SSH key (useful
# when ssh-agent has multiple keys loaded and the default one doesn't have
# push access to this repo).
# GIT_SSH_KEY=/Users/you/.ssh/id_ed25519_personal

# --- Windows release (only needed to run `npm run release:win` on a Windows box) ---
# SHA1 thumbprint of a code-signing cert installed in the Windows cert store.
# When set, electron-builder signs every produced .exe (installer + inner app
# + uninstaller) with sha256 + RFC 3161 timestamp from Sectigo, and the build
# verifies the signature with signtool /pa before uploading.
# Leave unset → installer ships UNSIGNED (SmartScreen warns first-time users).
# WINDOWS_CERT_THUMBPRINT=
