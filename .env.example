# Required: AI provider used by the @grok reply generator
ANTHROPIC_API_KEY=

# Optional: switch the detector's AI provider to OpenAI from the UI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Release credentials (only needed to run `npm run release:mac`) ---
# Generate an app-specific password at https://appleid.apple.com → Sign-In and Security
# Team ID is the 10-char string in your Developer ID Application certificate.
# APPLE_ID=you@example.com
# APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx
# APPLE_TEAM_ID=FT97GD7996
